```
// ── Grammar (PEG-style) ──

Query     ← RECALL / TRACE / FIND / SIMULATE / COMPOSE / SUMMARIZE / VIEW / COMPUTE
RECALL    ← 'RECALL' Target Filters? Ordering? Limit?
TRACE     ← 'TRACE' Aspect 'ABOUT' Topic 'OVER' TimeRange ShowClause?
FIND      ← 'FIND' Pattern 'IN' Scope Filters? ConfidenceClause?
SIMULATE  ← 'SIMULATE' 'DECISION' 'AT' Timestamp 'GIVEN' KnowledgeSpec 
             'COMPARE' 'WITH' ComparisonTarget?
COMPOSE   ← 'COMPOSE' Target 'FROM' SourceList 'WHERE' Filters 
             'WITH' ConsentClause
SUMMARIZE ← 'SUMMARIZE' Target GroupClause? TimeClause?
VIEW      ← 'VIEW' Target 'THROUGH' LensSpec FocusClause? DepthClause?
COMPUTE   ← 'COMPUTE' Expression 'OVER' Scope Filters?

// ── Examples ──

// Retrieve memories with complex filtering
RECALL memories 
  WHERE type = 'episodic' 
    AND involves('Alice') 
    AND emotional_valence > 0.5 
    AND confidence > 0.7
  ORDER BY salience DESC
  LIMIT 20

// Trace belief evolution over time  
TRACE beliefs ABOUT "artificial intelligence ethics" OVER 2020..2025
  SHOW changes, influences, contradictions, confidence_trajectory

// Find patterns in decision-making
FIND patterns IN decisions
  WHERE domain = 'career'
  CORRELATE WITH outcomes AFTER 6 MONTHS
  CONFIDENCE > 0.6

// Counterfactual simulation
SIMULATE DECISION AT "2023-03-15" 
  GIVEN knowledge.as_of("2024-01-01")
  COMPARE WITH actual_outcome

// Cross-user composition with consent
COMPOSE shared_context
  FROM [self, did:key:z6Mkf5..., did:key:z6Mkq7...]
  WHERE project = 'sovereign-memory' AND time IN 2024Q3..2024Q4
  WITH consent_proof REQUIRED

// Summarize with grouping
SUMMARIZE interactions WITH person('Bob')
  GROUP BY topic, emotional_valence
  OVER LAST 2 YEARS

// Ontological lensing
VIEW life_memories THROUGH lens('causal')
  FOCUS ON topic('health')
  DEPTH 3

// Computation over memories
COMPUTE correlation(
  RECALL memories WHERE tag = 'exercise',
  RECALL memories WHERE tag = 'productivity'
) OVER LAST 1 YEAR
  GRANULARITY week
