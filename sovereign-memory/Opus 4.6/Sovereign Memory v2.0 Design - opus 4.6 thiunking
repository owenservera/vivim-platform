**MQL Execution Engine:**

```rust
pub struct MQLEngine {
    parser: MQLParser,       // PEG parser → AST
    planner: QueryPlanner,   // AST → Execution Plan
    executor: QueryExecutor, // Plan → Results
}

impl MQLEngine {
    pub fn execute(&self, query: &str, store: &MemoryStore) -> Result<MQLResult> {
        // 1. Parse query into AST
        let ast = self.parser.parse(query)?;
        
        // 2. Generate execution plan (choose optimal indices)
        let plan = self.planner.plan(&ast, store.available_indices())?;
        
        // 3. Explain the plan (transparency)
        let explanation = plan.explain();
        
        // 4. Execute against the store
        let raw_results = self.executor.execute(&plan, store)?;
        
        // 5. Post-process (lensing, aggregation, etc.)
        let results = self.post_process(raw_results, &ast)?;
        
        Ok(MQLResult {
            data: results,
            execution_plan: explanation,
            confidence: self.assess_result_confidence(&results),
            caveats: self.identify_caveats(&results, &ast),
        })
    }
}
