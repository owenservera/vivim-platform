{
  "framework": "docusaurus",
  "buildCommand": "cd vivim.docs.context && bun run build",
  "outputDirectory": "vivim.docs.context/build",
  "installCommand": "cd vivim.docs.context && bun install",
  "rewrites": [
    {
      "source": "/docs/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/docs/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
