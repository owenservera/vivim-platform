    "devCommand": "npm run dev",
    "scripts": {
      "dev": "bun run dev:core",
      "dev:core": "concurrently --kill-others --prefix \"[{name}]\" --names \"PWA,SRV,WS,ADM\" --prefix-colors \"cyan,green,yellow,magenta\" \"bun run dev:pwa\" \"bun run dev:server\" \"bun run dev:network:ws\" \"bun run dev:admin\"",
      "dev:all": "concurrently --kill-others --prefix \"[{name}]\" --names \"PWA,SRV,WS,ADM,DASH,AGNT\" --prefix-colors \"cyan,green,yellow,magenta,blue,white\" \"bun run dev:pwa\" \"bun run dev:server\" \"bun run dev:network:ws\" \"bun run dev:admin\" \"bun run dev:dashboard\" \"bun run dev:agent\"",
      "dev:debug": "LOG_LEVEL=debug DEBUG=true bun run dev:core",
      "dev:pwa": "cd pwa && bun run dev",
      "dev:server": "cd server && bun run dev",
      "dev:network": "cd network && bun run dev",
      "dev:network:ws": "cd network && bun run dev:ws",
      "dev:admin": "cd admin-panel && bun run dev",
      "dev:dashboard": "cd sdk/apps/public-dashboard && bun run dev",
      "dev:agent": "cd sdk/apps/publishing-agent && bun run dev",
      "dev:clean": "node scripts/dev-with-cleanup.js",
      "dev:cleanup": "node scripts/force-cleanup.js",
      "stop": "node scripts/force-cleanup.js",
      "setup": "bun run setup:deps && bun run setup:db",
      "setup:deps": "bun install",
      "setup:db": "cd server && bun run db:generate && bun run db:migrate && cd ../network && bun run db:generate",
      "setup:redis": "bun run setup-redis.ts",
      "start": "concurrently --kill-others --prefix \"[{name}]\" --names \"PWA,SRV,WS,ADM\" --prefix-colors \"cyan,green,yellow,magenta\" \"cd pwa && bun run preview\" \"cd server && bun run start\" \"cd network && bun run start\" \"cd admin-panel && bun run preview\"",
      "build": "bun install && cd pwa && bun run build && cd ../server && bun run build && cd ../network && bun run build && cd ../admin-panel && bun run build",
      "build:all": "bun run build && cd sdk && bun run build && cd apps/public-dashboard && bun run build",
      "test": "bun test && cd pwa && bun test && cd ../server && bun test && cd ../network && bun test && cd ../admin-panel && bun test",
      "clear-cache": "bunx rimraf node_modules **/node_modules bun.lock **/bun.lock bun.lockb **/bun.lockb"
    }
  },
