# =============================================================================
# VIVIM - Root .gitignore
# =============================================================================

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
**/node_modules/
.pnp
.pnp.js

# =============================================================================
# Build Outputs
# =============================================================================
dist/
**/dist/
build/
**/build/
.next/
out/

# =============================================================================
# Environment Files
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
bun-debug.log*
dev-browser-dump.log
logs/
*.log.*

# =============================================================================
# Testing
# =============================================================================
coverage/
**/coverage/
.nyc_output/
.playwright/
test-results/
**/test-results/
playwright-report/
**/playwright-report/

# =============================================================================
# Editor Directories & Files
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# OS Files
# =============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.db
*.db-journal
Desktop.ini
*.lnk
*.shortcut
desktop.ini

# =============================================================================
# Binary & Media Files (Not needed in repo)
# =============================================================================
*.pptx
*.ppt
*.pdf
*.docx
*.doc
*.xlsx
*.xls
*.psd
*.ai
*.sketch
*.fig
*.mp4
*.mp3
*.mov
*.avi
*.wmv
*.flv
*.wav
*.m4a
*.webm
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz
*.bz2
*.gz
*.exe
*.msi
*.dmg
*.pkg
*.app
*.iso
*.bak
*.backup
*.dump
*.sqlite
*.sqlite3

# =============================================================================
# Lock Files (keep bun.lock, ignore others)
# =============================================================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Bun
# =============================================================================
# Keep bun.lock for reproducible builds
bun.lockb

# =============================================================================
# TypeScript/Vite Cache
# =============================================================================
*.tsbuildinfo
.vite/
**/.vite/
tsconfig.tsbuildinfo
.rpt2_cache/

# =============================================================================
# Supabase (keep migrations, ignore temp)
# =============================================================================
supabase/.temp/

# =============================================================================
# Vercel
# =============================================================================
.vercel
!pwa/.vercel

# =============================================================================
# Documentation Archives (Keep only active docs)
# =============================================================================
.archive/
**/.archive/
_legacy/
**/_legacy/
vivim-docs/08-ARCHIVE/
vivim-docs/VIVIM.docs/.archive/
vivim-docs/VIVIM.docs/VIVIM.docs/.archive/

# =============================================================================
# AI Tool Outputs & Sessions
# =============================================================================
.omc/
**/.omc/
.sisyphus/
**/.sisyphus/
.agents/
**/.agents/
.analysis/
**/.analysis/
.dev/
**/.dev/
.qwen/
**/.qwen/

# =============================================================================
# Exported/Generated Markdowns (Not source of truth)
# =============================================================================
qwen-code-export-*.md
* export *.md
*_export_*.md

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.swp
*.swo
*~
*.orig
*.bak
*.backup
*.cache

# =============================================================================
# Docker
# =============================================================================
.dockerenv
.dockerignore.local

# =============================================================================
# Misc
# =============================================================================
$null
running_services.txt
*.pid
*.seed
*.pid.lock
*.cert
*.pem
*.key
!.github/**/*.key (if needed for workflows)
secrets/
**/secrets/
credentials/
**/credentials/

# =============================================================================
# Documentation Duplicates
# =============================================================================
vivim-docs/VIVIM.docs/VIVIM.docs/
vivim-docs/VIVIM.docs/vivim.docs.context/
vivim.docs.context/

# =============================================================================
# Embedded Repositories
# =============================================================================
vivim-pitch/
**/.git

# =============================================================================
# Build Artifacts
# =============================================================================
*.artifact
*.meta
*.d.ts.map

# =============================================================================
# Prisma
# =============================================================================
prisma/migrations/**/README.md
prisma/migrations/**/migration_lock.toml

# =============================================================================
# Sentry
# =============================================================================
.sentryclirc
*.js.map (keep for production debugging)
!pwa/dist/**/*.js.map

# =============================================================================
# OMC Session Files
# =============================================================================
*.jsonl
agent-replay-*.jsonl

# =============================================================================
# Cleanup Prevention - Debug/Test Artifacts
# =============================================================================
# Session dumps
session-*.md
session-*.json

# Ad-hoc test files (root level)
test-*.ts
test-*.js
verify-*.ts
capture-*.ts
cleanup-*.ts
setup-*.ts

# Server root debug files (keep index.js, eslint.config.js, vitest.config.js)
server/analyze-*.js
server/check-*.js
server/debug-*.js
server/find-*.js
server/quick-*.js
server/*_test.js
server/test-*.js
server/test-*.cjs
server/debug-*.html
server/bun-test*.txt
server/test-*-log*.txt

# Compiled JS in common/ (TypeScript build artifacts)
common/*.js
common/*.js.map
common/*.d.ts
common/*.d.ts.map
network/src/common/*.js
network/src/common/*.js.map
network/src/common/*.d.ts
network/src/common/*.d.ts.map

# Windows reserved names (prevents accidental creation)
nul
con
prn
aux

# PWA dev service worker outputs
pwa/dev-dist/

# ChatGPT exports extracted data
chatgpt-exports/extracted/

# Screenshot artifacts
screenshots/*.png

# AI design docs in root (should be in docs/)
* opus *.md

# Mintlify docs build output
.mint/
docs/.mint/
