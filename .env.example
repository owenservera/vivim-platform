# =============================================================================
# VIVIM ROOT ENVIRONMENT CONFIGURATION
# =============================================================================
# This file is for REFERENCE ONLY. Each sub-package has its own .env file.
# Copy this to .env and then copy relevant variables to each sub-package.
#
# Sub-package .env locations:
#   - pwa/.env
#   - server/.env
#   - network/.env
#   - admin-panel/.env
# =============================================================================

# =============================================================================
# SHARED CONFIGURATION (Used by multiple services)
# =============================================================================

# Server URL (used by PWA and Admin Panel to connect to backend)
SHARED_SERVER_URL=http://localhost:3000

# WebSocket URL (for Yjs sync and real-time features)
SHARED_WS_URL=ws://localhost:3000

# API Key for development
SHARED_API_KEY=sk-vivim-dev-key-123456789

# Sentry Configuration (Shared)
# Get your DSN from https://sentry.io/
# Required for error tracking and performance monitoring
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_RELEASE=vivim@1.0.0
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false

# =============================================================================
# SERVER CONFIGURATION (server/.env)
# =============================================================================

# Database
SERVER_DATABASE_URL="postgresql://openscroll:openscroll_dev_password@localhost:5432/openscroll"
SERVER_DATABASE_SSL_REQUIRED=false

# Redis (Optional - In-memory fallback if not configured)
SERVER_REDIS_URL=redis://localhost:6379

# Server Settings
SERVER_NODE_ENV=development
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
SERVER_TRUST_PROXY=false

# Security
SERVER_SESSION_SECRET=your-session-secret-here-min-32-chars
SERVER_JWT_SECRET=your-jwt-secret-here-min-32-chars

# CORS (development allows all local origins by default)
SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Rate Limiting
SERVER_RATE_LIMIT_MAX=1000
SERVER_RATE_LIMIT_WINDOW_MS=900000

# Google OAuth (optional - for Sign In)
SERVER_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SERVER_GOOGLE_CLIENT_SECRET=your-google-client-secret
SERVER_GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
SERVER_GOOGLE_SUCCESS_REDIRECT=http://localhost:5173
SERVER_SKIP_AUTH_FOR_DEVELOPMENT=false

# Logging
SERVER_LOG_LEVEL=info
SERVER_LOG_FILE_PATH=./logs

# Swagger
SERVER_ENABLE_SWAGGER=true

# Z.AI Integration (Primary AI Provider)
SERVER_ZAI_API_KEY=
SERVER_ZAI_MODEL=glm-4.7-flash
SERVER_ZAI_BASE_URL=https://api.z.ai/api/paas/v4
SERVER_ZAI_EMBEDDING_DIMENSIONS=1536
SERVER_COMPACTION_MODEL=glm-4.7-flash
SERVER_ZAI_EMBEDDING_FALLBACK_TO_MOCK=false

# Librarian Worker
SERVER_LIBRARIAN_ENABLED=true
SERVER_LIBRARIAN_BATCH_SIZE=20
SERVER_LIBRARIAN_COOLDOWN_MINUTES=30
SERVER_ENABLE_IDLE_DETECTION=true
SERVER_CONVERSATION_IDLE_TIMEOUT_MINUTES=5

# P2P Network
SERVER_P2P_LISTEN_ADDRESSES=/ip4/0.0.0.0/tcp/4001,/ip4/0.0.0.0/tcp/4002/ws
SERVER_P2P_BOOTSTRAP_PEERS=

# =============================================================================
# PWA CONFIGURATION (pwa/.env)
# =============================================================================

# API Configuration
PWA_VITE_API_BASE_URL=http://localhost:3000
PWA_VITE_API_URL=http://localhost:3000
PWA_VITE_WS_URL=ws://localhost:3000
PWA_VITE_FALLBACK_SERVER=http://localhost:3000
PWA_VITE_API_KEY=sk-vivim-dev-key-123456789

# Development Features
PWA_VITE_DEV_TOOLS=true
PWA_VITE_USE_LOCAL_FEED=false

# =============================================================================
# NETWORK ENGINE CONFIGURATION (network/.env)
# =============================================================================

# Network Settings
NETWORK_PORT=1235
NETWORK_HOST=0.0.0.0

# Logging
NETWORK_LOG_LEVEL=info
NETWORK_DEBUG=false

# =============================================================================
# ADMIN PANEL CONFIGURATION (admin-panel/.env)
# =============================================================================

# API Configuration
ADMIN_VITE_API_URL=http://localhost:3000
ADMIN_VITE_DEBUG=true

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to .env (for reference):
#    cp .env.example .env
#
# 2. Create .env files for each sub-package:
#    cp server/.env.example server/.env
#    cp pwa/.env.example pwa/.env
#    cp network/.env.example network/.env
#    cp admin-panel/.env.example admin-panel/.env
#
# 3. Update the values in each .env file as needed
#
# 4. Run development server:
#    bun run dev
#
# =============================================================================
