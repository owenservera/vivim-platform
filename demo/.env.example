# VIVIM Investor Demo Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# DEMO MODE
# ============================================================================
# Enable demo mode for investor presentations
VIVIM_DEMO_MODE=true

# Demo persona (Alex Chen - pre-seeded user)
DEMO_USER_DID=did:key:demo-alex-chen

# ============================================================================
# DATABASE (uses server DATABASE_URL)
# ============================================================================
# Inherit from server/.env - ensure DATABASE_URL is set

# ============================================================================
# SERVER
# ============================================================================
# Demo server URL (where the app runs during demo)
DEMO_SERVER_URL=http://localhost:3000
DEMO_APP_URL=http://localhost:5173

# ============================================================================
# SCREENSHOT CAPTURE
# ============================================================================
# Playwright viewport for screenshots
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# Output directory for screenshots
SCREENSHOT_OUTPUT_DIR=./screenshots

# ============================================================================
# SLIDE GENERATION
# ============================================================================
# Output directory for generated slides
SLIDES_OUTPUT_DIR=./slides

# Default slide template
DEFAULT_SLIDE_TEMPLATE=investor
