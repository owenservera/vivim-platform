# VIVIM Network Engine Configuration
# Copy this file to .env and adjust values as needed.

# Sentry Configuration
# Get your DSN from https://sentry.io/
# Required for error tracking and performance monitoring
SENTRY_DSN=https://your-network-dsn@sentry.io/project-id

# Optional: Override release version
# Format: vivim-network@<version>
SENTRY_RELEASE=vivim-network@0.1.0

# Optional: Override environment (defaults to NODE_ENV)
SENTRY_ENVIRONMENT=development

# Performance sampling rates (0.0 to 1.0)
# Production: 0.1 (10%), Development: 1.0 (100%)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enable Sentry debug mode (only in development)
SENTRY_DEBUG=false

# Networking
PORT=1235
HOST=0.0.0.0

# libp2p configurations (optional)
# LIBP2P_BOOTSTRAP_PEERS=/ip4/127.0.0.1/tcp/1234/p2p/...

# Logging
LOG_LEVEL=info
DEBUG=false
