```
// Protocol specification (high-level)

UMP/1.0

// ── Core Operations ──

// Store a memory (to any UMP-compliant backend)
PUT /memories/{cid}
  Content-Type: application/memory-dna+cbor
  Authorization: DID-Auth {signature}
  Body: MemoryDNA (encrypted)

// Retrieve a memory
GET /memories/{cid}
  Authorization: DID-Auth {signature}
  → 200: MemoryDNA (encrypted)
  → 403: Access denied (ABE policy not satisfied)

// Query memories
POST /memories/query
  Content-Type: application/mql
  Authorization: DID-Auth {signature}
  Body: MQL query
  → 200: MQLResult (encrypted per-memory)

// ── Consent Protocol ──

// Request access to someone's memories
POST /consent/request
  From: did:key:requester
  To: did:key:owner
  Scope: { types: [...], topics: [...], time_range: ..., purpose: "..." }
  Duration: "30 days"
  → 202: ConsentRequest created

// Grant consent (by owner)
POST /consent/grant/{request_id}
  Authorization: DID-Auth {owner_signature}
  Policy: ABEPolicy  // Cryptographic access control
  → 200: ABEUserKey (encrypted for requester)

// Revoke consent
DELETE /consent/{grant_id}
  Authorization: DID-Auth {owner_signature}
  → 200: Revoked (new epoch key issued)

// ── Sync Protocol ──

// Advertise available memories (content-addressed)
POST /sync/advertise
  Body: { cids: [CID], vector_clock: VectorClock }

// Request missing memories
POST /sync/pull
  Body: { wanted: [CID] }
  → 200: Stream<MemoryDNA>

// CRDT-based conflict resolution
POST /sync/merge
  Body: { local_state: CRDTState, remote_state: CRDTState }
  → 200: MergedState

// ── Discovery (privacy-preserving) ──

// Find if a memory exists without revealing content
POST /discovery/probe
  Body: { content_hash: BlindedHash }
  → 200: { exists: bool, provider_hints: [...] }

// ── Commitment Anchoring ──

// Anchor a temporal commitment
POST /commitments/anchor
  Body: TemporalCommitment
  → 200: AnchorProof

// Verify a commitment
GET /commitments/verify/{commitment_hash}
  → 200: VerificationResult
