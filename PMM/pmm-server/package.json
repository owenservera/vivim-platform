{
  "name": "@vivim/pmm-server",
  "version": "1.0.0",
  "description": "PMM Backend API Server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "bun run prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@hono/node-server": "^1.17.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^7.4.2",
    "@types/multer": "2.1.0",
    "ai": "^4.3.16",
    "date-fns": "^4.1.0",
    "hono": "^4.8.4",
    "socket.io": "^4.8.3",
    "tree-sitter": "^0.22.4",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "prisma": "^7.4.2",
    "typescript": "^5.9.3"
  }
}
