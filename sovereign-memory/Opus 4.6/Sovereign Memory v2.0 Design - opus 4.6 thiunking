### 5.2 Hebbian Cognitive DAG

Edges in the cognitive graph evolve over time based on usage patterns:

```rust
pub struct HebbianEdgeState {
    pub weight: f64,                    // Current connection strength [0, 1]
    pub activation_count: u64,          // Times co-activated
    pub last_activation: Timestamp,
    pub creation_time: Timestamp,
    pub decay_rate: f64,                // Per-day decay factor
    pub reinforcement_history: Vec<ReinforcementEvent>,
}

impl HebbianEdgeState {
    /// Hebbian learning rule: "memories that fire together wire together"
    pub fn co_activate(&mut self, now: Timestamp) {
        // Apply time-based decay since last activation
        let days_elapsed = (now - self.last_activation).as_days();
        self.weight *= (-self.decay_rate * days_elapsed).exp();
        
        // Strengthen connection (bounded sigmoid growth)
        let reinforcement = 0.1 * (1.0 - self.weight); // Diminishing returns
        self.weight = (self.weight + reinforcement).min(1.0);
        
        self.activation_count += 1;
        self.last_activation = now;
        self.reinforcement_history.push(ReinforcementEvent {
            timestamp: now,
            delta: reinforcement,
            context: ActivationContext::current(),
        });
    }
    
    /// Current effective weight, accounting for time decay
    pub fn effective_weight(&self, now: Timestamp) -> f64 {
        let days_elapsed = (now - self.last_activation).as_days();
        self.weight * (-self.decay_rate * days_elapsed).exp()
    }
    
    /// Has this edge decayed below the pruning threshold?
    pub fn is_prunable(&self, now: Timestamp, threshold: f64) -> bool {
        self.effective_weight(now) < threshold
            && self.activation_count < 3  // Protect rarely but recently used
    }
}

