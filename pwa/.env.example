# ============================================================================
# VIVIM PWA - ENVIRONMENT VARIABLES
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED for production)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# ----------------------------------------------------------------------------
# Sentry Configuration
# ----------------------------------------------------------------------------
# Get your DSN from https://sentry.io/
# Required for client-side error tracking
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Optional: Override release version
VITE_SENTRY_RELEASE=vivim-pwa@1.0.0

# Optional: Package version (auto-populated)
VITE_PACKAGE_VERSION=1.0.0

# Enable Sentry debug mode (only in development)
VITE_SENTRY_DEBUG=false

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------
VITE_APP_NAME=VIVIM
VITE_APP_DESCRIPTION=Own Your AI
VITE_APP_URL=http://localhost:5173

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
VITE_ENABLE_DEBUG_TOOLS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_SESSION_REPLAY=false

# ----------------------------------------------------------------------------
# Development Settings
# ----------------------------------------------------------------------------
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug
