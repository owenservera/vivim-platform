pub struct DreamCycleReport {
    pub cycle_id: Uuid,
    pub started_at: Timestamp,
    pub completed_at: Timestamp,
    pub phases: Vec<DreamPhaseReport>,
    pub proposals: Vec<DreamProposal>,
    pub auto_applied: Vec<AutoAppliedChange>,
    pub metrics: DreamMetrics,
}

impl DreamEngine {
    pub async fn run_cycle(&self, store: &MemoryStore) -> DreamCycleReport {
        let mut report = DreamCycleReport::new();
        
        // ── Phase 1: Consolidation ──
        // Find near-duplicate memories (cosine similarity > 0.92)
        let duplicates = self.find_near_duplicates(store).await;
        for pair in duplicates {
            report.proposals.push(DreamProposal::Merge {
                memories: pair,
                proposed_merge: self.generate_merge(pair).await,
                confidence: pair.similarity,
                rationale: format!(
                    "These memories share {:.0}% semantic overlap. \
                     Merging would reduce redundancy while preserving unique details.",
                    pair.similarity * 100.0
                ),
            });
        }
        
        // ── Phase 2: Hebbian Update ──
        // Strengthen edges between memories co-retrieved in recent sessions
        let co_retrievals = self.analyze_retrieval_sessions(store).await;
        for (a, b, count) in co_retrievals {
            let edge = store.get_or_create_edge(a, b, EdgeType::Semantic);
            for _ in 0..count {
                edge.co_activate(Timestamp::now());
            }
            report.auto_applied.push(AutoAppliedChange::EdgeStrengthened {
                from: a, to: b, new_weight: edge.effective_weight(Timestamp::now()),
            });
        }
        
        // ── Phase 3: Pattern Discovery ──
        let clusters = ClusterEngine::detect_communities(store.dag(), Default::default());
        let analogies = ClusterEngine::discover_analogies(store.dag(), 0.7);
        let bridges = self.find_cross_cluster_bridges(&clusters).await;
        
        for analogy in analogies {
            report.proposals.push(DreamProposal::AnalogicalInsight {
                domain_a: analogy.source_domain,
                domain_b: analogy.target_domain,
                mapping: analogy.mapping,
                confidence: analogy.structural_similarity,
                narrative: self.narrate_analogy(&analogy).await,
            });
        }
        
        for bridge in bridges {
            report.proposals.push(DreamProposal::NovelConnection {
                memory_a: bridge.from,
                memory_b: bridge.to,
                connection_type: bridge.proposed_edge_type,
                rationale: bridge.rationale,
                confidence: bridge.confidence,
            });
        }
        
        // ── Phase 4: Contradiction Detection ──
        let contradictions = self.detect_contradictions(store).await;
        for contradiction in contradictions {
            report.proposals.push(DreamProposal::ContradictionAlert {
                memory_a: contradiction.memory_a,
                memory_b: contradiction.memory_b,
                tension: contradiction.description,
                confidence: contradiction.confidence,
                suggested_resolution: contradiction.suggestion,
            });
        }
        
        // ── Phase 5: Salience Decay ──
        let decayed = self.apply_decay(store).await;
        let archive_candidates = decayed.iter()
            .filter(|m| m.new_salience < store.config().archive_threshold)
            .collect();
        
        for memory in archive_candidates {
            report.proposals.push(DreamProposal::ArchiveCandidate {
                memory: memory.cid,
                current_salience: memory.new_salience,
                last_accessed: memory.last_accessed,
                rationale: format!(
                    "This memory hasn't been accessed in {} days and its \
                     salience has decayed to {:.2}. Consider archiving.",
                    memory.days_since_access, memory.new_salience
                ),
            });
        }
        
        // ── Phase 6: Anticipatory Pre-loading ──
        let predictions = self.predict_upcoming_needs(store).await;
        for prediction in predictions {
            store.ensure_hot(prediction.memory_cid).await;
            report.auto_applied.push(AutoAppliedChange::PreLoaded {
                memory: prediction.memory_cid,
                reason: prediction.rationale,
                predicted_need_time: prediction.expected_time,
                confidence: prediction.confidence,
            });
        }
        
        // ── Phase 7: Schema Evolution ──
        let schema_proposals = self.analyze_schema_fit(store).await;
        for proposal in schema_proposals {
            report.proposals.push(DreamProposal::SchemaEvolution {
                change: proposal,
            });
        }
        
        report
    }
}
```

